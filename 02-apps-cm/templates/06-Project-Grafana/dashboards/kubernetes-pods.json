{
  "title": "Kubernetes Logs (Loki)",
  "uid": "k8s-logs-loki",
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "loki"
        },
        "query": "label_values(namespace)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "loki"
        },
        "query": "label_values({namespace=~\"$namespace\"}, pod)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "loki"
        },
        "query": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "query",
        "type": "textbox",
        "label": "Search Logs"
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Log Volume (Logs/sec)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |~ \"(?i)$query\" [$__interval]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top Namespaces (Log Volume)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(5, sum by (namespace) (count_over_time({namespace=~\"$namespace\"}[$__interval])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top Pods (Log Volume)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(5, sum by (pod) (count_over_time({namespace=~\"$namespace\"}[$__interval])))"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 12 },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |~ \"(?i)$query\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      }
    }
  ]
}