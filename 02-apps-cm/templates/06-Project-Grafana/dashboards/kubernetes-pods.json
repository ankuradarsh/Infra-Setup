{
  "title": "Kubernetes Logs (Loki) - Advanced",
  "uid": "k8s-logs-loki-advanced",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },

  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "loki" },
        "query": "label_values(namespace)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "loki" },
        "query": "label_values({namespace=~\"$namespace\"}, pod)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki" },
        "query": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "level",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "error,warn,info,debug"
      },
      {
        "name": "query",
        "type": "textbox",
        "label": "Search Logs"
      }
    ]
  },

  "panels": [

    {
      "type": "timeseries",
      "title": "Log Rate (logs/sec)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate({namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |~ \"(?i)$query\" [1m]))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate({namespace=~\"$namespace\"} |= \"error\" [1m]))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Warning Rate",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate({namespace=~\"$namespace\"} |= \"warn\" [1m]))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Top Noisy Pods",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(5, sum by (pod) (rate({namespace=~\"$namespace\"}[5m])))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Top Noisy Containers",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(5, sum by (container) (rate({namespace=~\"$namespace\"}[5m])))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Logs by Level",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({namespace=~\"$namespace\"} |~ \"(?i)(error|warn|info|debug)\" [$__interval]))"
        }
      ]
    },

    {
      "type": "logs",
      "title": "Live Logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 14 },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |~ \"(?i)$query\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      }
    }
  ]
}